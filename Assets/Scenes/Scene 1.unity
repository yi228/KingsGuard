--- !u!114 &946375279
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 946375277}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 946cfe10a5b7826468d640bf49568ccd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  talkText: {fileID: 1320895264}
  nameText: {fileID: 906422865}
  talkList:
  - "\uB85C\uBC84\uD2B8^\uD3D0\uD558\uC758 \uAE34\uAE09 \uD638\uCD9C\uC744 \uBC1B\uACE0
    \uC654\uB294\uB370 \uC774\uAC8C \uB300\uCCB4 \uBB34\uC2A8\uC77C\uC774\uC9C0?! "
  - "\uB85C\uBC84\uD2B8^\uC131 \uC548\uC5D0 \uAD34\uBB3C\uB4E4\uC774... "
  - "\uB85C\uBC84\uD2B8^\uBE68\uB9AC \uD3D0\uD558\uB97C \uAD6C\uD558\uB7EC \uAC00\uC57C\uACA0\uAD70.^\uB05D "
  - "\uBC14\uC2A4\uC778^\uB85C\uBC84\uD2B8 \uACF5! \uD3D0\uD558\uAC00..! "
  - "\uB85C\uBC84\uD2B8^\uBC14\uC2A4\uC778 \uB300\uACF5! \uC9C4\uC815\uD558\uACE0
    \uB9D0\uD574\uBCF4\uC2DC\uC624! \uD3D0\uD558\uB294 \uC5B4\uB514 \uC788\uC18C! "
  - "\uBC14\uC2A4\uC778^\uB098\uB3C4 \uBAA8\uB974\uC624.. \uAD34\uBB3C\uB4E4\uC774
    \uD3D0\uD558\uB97C \uC7A1\uC544\uAC14\uC18C! \uD3D0\uD558\uB97C \uAD6C\uD574\uC8FC\uC2DC\uC624
    \uB85C\uBC84\uD2B8 \uACF5! "
  - "\uB85C\uBC84\uD2B8^\uC54C\uACA0\uC18C! \uC5EC\uAE30 \uAE30\uB2E4\uB9AC\uACE0
    \uACC4\uC2DC\uC624.^\uB05D "
  - "\uB85C\uBC84\uD2B8^\uD3D0\uD558! \uC81C\uAC00 \uC654\uC2B5\uB2C8\uB2E4! \uD0C8\uCD9C\uB85C\uB97C
    \uB6AB\uC744\uD14C\uB2C8 \uD0C8\uCD9C\uD558\uC2DC\uC8E0! "
  - "\uC655^\uC624 \uB85C\uBC84\uD2B8...\uC624\uBA74 \uC548 \uB3FC!! "
  - "\uB85C\uBC84\uD2B8^\uD3D0\uD558! \uADF8\uAC8C \uBB34\uC2A8 \uB9D0\uC500\uC774\uC2ED\uB2C8\uAE4C! "
  - "\uC655^\uB204\uAD70\uAC00 \uB0B4\uAC8C \uC18D\uC0AD\uC774\uACE0 \uC788\uC5B4...
    \uB110 \uC8FD\uC774\uB77C\uACE0... "
